# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=study_material_db
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here
DB_DRIVER=com.mysql.cj.jdbc.Driver

# Application Settings
APP_PORT=8080
APP_PROFILE=dev
APP_BASE_URL=http://localhost:8080

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_secure
JWT_EXPIRATION=86400000

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Admin SDK
FIREBASE_ADMIN_SDK_PATH=./firebase-adminsdk.json

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_or_generated_token
MAIL_FROM=noreply@studycorner.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000

# Frontend Configuration
FRONTEND_URL=http://localhost:4200
API_URL=http://localhost:8080/api

# File Upload Configuration
MAX_FILE_SIZE=50MB
MAX_REQUEST_SIZE=50MB

# Logging Configuration
LOG_LEVEL_SECURITY=DEBUG
LOG_LEVEL_APP=DEBUG
